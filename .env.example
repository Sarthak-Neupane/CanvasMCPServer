# Canvas MCP Server Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file.

# Your Canvas API access token (generate one at <your-canvas-url>/profile
# under "Approved Integrations").
CANVAS_API_TOKEN=your_api_token_here

# Base API URL of your Canvas instance. Must end at /api (NOT /api/v1) --
# the server posts GraphQL queries to {CANVAS_BASE_URL}/graphql.
# Use your institution's Canvas domain. Note: canvas.instructure.com
# (Free-for-Teacher) was permanently discontinued in 2026.
CANVAS_BASE_URL=https://your-school.instructure.com/api

# Request timeout in seconds
CANVAS_TIMEOUT=30

# Optional: Debug settings
DEBUG=false
LOG_LEVEL=INFO
